NODE_ENV=production

POSTGRES_USER=newsletter
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=newsletter
DATABASE_URL=postgres://newsletter:replace-with-a-long-random-password@db:5432/newsletter

APP_URL=https://newsletter.example.com
AUTH_COOKIE_NAME=newsletter_session
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_SESSION_DAYS=30
AUTH_ALLOWED_EMAILS=tester@example.com
AUTH_ALLOWED_EMAIL_DOMAINS=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=newsletter-tool@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Newsletter Tool <newsletter-tool@example.com>"

MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-minio-root-user
S3_SECRET_ACCESS_KEY=replace-with-minio-root-password
S3_BUCKET=newsletter-assets
PUBLIC_ASSET_BASE_URL=https://assets.example.com/newsletter-assets
