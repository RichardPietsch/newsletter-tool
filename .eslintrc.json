{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "ignorePatterns": [".next/", "node_modules/", "coverage/", "playwright-report/", "test-results/"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["@next/next"],
  "settings": {
    "next": {
      "rootDir": ["./"]
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": "warn",
    "@next/next/no-img-element": "off"
  },
  "overrides": [
    {
      "files": ["**/*.{ts,tsx}"],
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "warn"
      }
    },
    {
      "files": ["app/**/*.{ts,tsx}", "components/**/*.{ts,tsx}", "email/**/*.{ts,tsx}", "lib/**/*.{ts,tsx}"],
      "rules": {
        "no-console": "error"
      }
    },
    {
      "files": ["*.config.*", "drizzle/**/*.{ts,tsx}", "scripts/**/*.{js,mjs,ts}"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["email/render-newsletter.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
